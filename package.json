{
  "name": "webhook-github-action",
  "version": "2.0.0",
  "description": "Job Automation System - AR/Credit Control/Senior Accountant",
  "main": "app.ts",
  "repository": "https://github.com/christophernemala/webhook-github-action",
  "author": "Christopher Nemala",
  "license": "MIT",
  "private": false,
  "scripts": {
    "build": "pnpm exec tsc",
    "start": "node dist/app.js",
    "dev": "tsnd --respawn app.ts",
