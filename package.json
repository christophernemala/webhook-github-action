  },
  "keywords": ["job-automation", "ar", "credit-control", "senior-accountant", "apify", "bayt"],
  "dependencies": {
    "@octokit/core": "^6.1.4",
    "apify-client": "^2.22.3",
    "express": "^5.0.1",
    "playwright": "^1.42.0",
    "standardwebhooks": "^1.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  }
}
